{
  "expo": {
    "name": "Family-Grocery-List",
    "slug": "Family-Grocery-List",
    "scheme": [
      "familygrocerylist",
      "com.googleusercontent.apps.1062088306859-g25274d26kfdh2joau9vnk0eharr8l9e"
    ],
    "version": "1.0.0",
    "platforms": [
      "android",
      "ios"
    ],
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "plugins": [
      [
        "react-native-bootsplash",
        {
          "logo": "./assets/branding/bootsplash-logo.svg",
          "logoWidth": 134,
          "background": "#59AC77",
          "assetsOutput": "assets/bootsplash",
          "android": {
            "darkContentBarsStyle": true
          }
        }
      ]
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.mehedi.FamilyGroceryList"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#59AC77"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.mehedi.FamilyGroceryList"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    }
  }
}
