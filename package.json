{
  "name": "family-grocery-list",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "start:clear": "expo start --clear",
    "android": "expo run:android",
    "ios": "expo run:ios --no-bundler",
    "start:dev": "expo start --dev-client --port 8090",
    "ios:dev": "npm run ios && npm run start:dev",
    "web": "expo start --web",
    "clean": "rm -rf node_modules package-lock.json && npm install",
    "clean:android": "cd android && ./gradlew clean -x app:externalNativeBuildCleanDebug -x app:externalNativeBuildCleanRelease && rm -rf build && rm -rf app/build && rm -rf app/.cxx && cd ..",
    "clean:ios": "cd ios && rm -rf Pods Podfile.lock build && pod install && cd ..",
    "build:android": "npm run build:android:apk",
    "build:android:apk": "cd android && ./gradlew assembleRelease && cd ..",
    "build:android:aab": "cd android && ./gradlew bundleRelease && cd ..",
    "lint": "eslint .",
    "lint:fix": "npm run lint -- --fix",
    "format": "prettier --check ./src/**/*.{ts,tsx}",
    "format:fix": "prettier --write ./src/**/*.{ts,tsx}",
    "prepare": "husky",
    "commitlint": "commitlint --from HEAD~1 --to HEAD --verbose",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@expo-google-fonts/dm-mono": "^0.4.2",
    "@expo-google-fonts/dm-sans": "^0.4.2",
    "@hookform/resolvers": "^5.2.2",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-google-signin/google-signin": "^16.1.2",
    "@react-navigation/bottom-tabs": "^7.15.9",
    "@react-navigation/native": "^7.2.2",
    "@react-navigation/native-stack": "^7.14.11",
    "@tanstack/react-query": "^5.100.5",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "expo": "~55.0.17",
    "expo-auth-session": "~55.0.15",
    "expo-crypto": "~55.0.14",
    "expo-dev-client": "~55.0.28",
    "expo-font": "~55.0.6",
    "expo-linear-gradient": "~55.0.13",
    "expo-splash-screen": "~55.0.19",
    "expo-status-bar": "~55.0.5",
    "expo-web-browser": "~55.0.14",
    "firebase": "^12.12.0",
    "lucide-react-native": "^1.8.0",
    "nativewind": "^4.2.3",
    "react": "19.2.0",
    "react-hook-form": "^7.73.1",
    "react-native": "0.83.9",
    "react-native-bootsplash": "^7.3.1",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-gifted-charts": "^1.4.76",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "4.23.0",
    "react-native-svg": "15.15.3",
    "react-native-worklets": "0.7.4",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^3.3.2",
    "yup": "^1.7.1",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@types/react": "~19.2.10",
    "@types/react-native": "^0.72.8",
    "babel-preset-expo": "~55.0.18",
    "eslint": "^9.39.4",
    "eslint-config-expo": "~10.0.0",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "prettier": "^3.8.3",
    "typescript": "~5.9.2"
  },
  "engines": {
    "node": ">=20.19.0"
  },
  "private": true
}
