rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function userDocPath(uid) {
      return /databases/$(database)/documents/users/$(uid);
    }

    function familyDocPath(familyId) {
      return /databases/$(database)/documents/families/$(familyId);
    }

    function inviteDocPath(code) {
      return /databases/$(database)/documents/family_invites/$(code);
    }

    function requesterDocExists() {
      return signedIn() && exists(userDocPath(request.auth.uid));
    }

    function requesterFamilyId() {
      return get(userDocPath(request.auth.uid)).data.get('familyId', null);
    }

    function isRequester(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function isFamilyMember(familyId) {
      return signedIn() && requesterFamilyId() == familyId;
    }

    function isOwnerOf(familyId) {
      return isFamilyMember(familyId)
        && exists(familyDocPath(familyId))
        && get(familyDocPath(familyId)).data.ownerId == request.auth.uid;
    }

    function validInviteForFamily(code, familyId) {
      return code is string
        && code.size() == 6
        && exists(inviteDocPath(code))
        && get(inviteDocPath(code)).data.familyId == familyId;
    }

    function selfProfileOnlyUpdate() {
      return request.resource.data.uid == resource.data.uid
        && request.resource.data.email == resource.data.email
        && request.resource.data.familyId == resource.data.familyId
        && request.resource.data.role == resource.data.role
        && request.resource.data.get('lastInviteCode', '') == resource.data.get('lastInviteCode', '')
        && request.resource.data.diff(resource.data).changedKeys().hasOnly(["displayName", "photoURL", "updatedAt"]);
    }

    function selfJoinOrCreateFamilyUpdate(uid) {
      return resource.data.familyId == null
        && request.resource.data.familyId is string
        && request.resource.data.familyId != ""
        && (request.resource.data.role == "member" || request.resource.data.role == "owner")
        && request.resource.data.uid == resource.data.uid
        && request.resource.data.email == resource.data.email
        && request.resource.data.displayName == resource.data.displayName
        && request.resource.data.photoURL == resource.data.photoURL
        && request.resource.data.lastInviteCode is string
        && validInviteForFamily(request.resource.data.lastInviteCode, request.resource.data.familyId)
        && request.resource.data.diff(resource.data).changedKeys().hasOnly(["familyId", "role", "lastInviteCode", "updatedAt"])
        && (
          request.resource.data.role == "member"
          || (
            exists(familyDocPath(request.resource.data.familyId))
            && get(familyDocPath(request.resource.data.familyId)).data.ownerId == uid
          )
        );
    }

    function selfLeaveFamilyUpdate() {
      return resource.data.familyId != null
        && request.resource.data.familyId == null
        && request.resource.data.role == "member"
        && request.resource.data.uid == resource.data.uid
        && request.resource.data.email == resource.data.email
        && request.resource.data.displayName == resource.data.displayName
        && request.resource.data.photoURL == resource.data.photoURL
        && request.resource.data.get('lastInviteCode', '') == resource.data.get('lastInviteCode', '')
        && request.resource.data.diff(resource.data).changedKeys().hasOnly(["familyId", "role", "updatedAt"]);
    }

    match /families/{familyId} {
      // Family docs are visible to members only.
      allow read: if isFamilyMember(familyId);

      allow create: if signedIn()
        && request.resource.data.ownerId == request.auth.uid
        && request.resource.data.id == familyId;

      allow update, delete: if isOwnerOf(familyId);
    }

    match /family_invites/{inviteCode} {
      // Safe join-code path: direct code lookup allowed for signed-in users.
      // Prevent broad collection listing of invite mappings.
      allow get: if signedIn();
      allow list: if false;

      allow create: if signedIn()
        && request.resource.data.code == inviteCode
        && request.resource.data.ownerId == request.auth.uid
        && request.resource.data.familyId is string
        && (
          (
            exists(familyDocPath(request.resource.data.familyId))
            && get(familyDocPath(request.resource.data.familyId)).data.ownerId == request.auth.uid
          )
          || (
            getAfter(familyDocPath(request.resource.data.familyId)).data.ownerId == request.auth.uid
          )
        );

      allow update, delete: if signedIn()
        && resource.data.familyId is string
        && isOwnerOf(resource.data.familyId);
    }

    match /users/{uid} {
      allow read: if isRequester(uid)
        || (
          requesterDocExists()
          && resource.data.familyId != null
          && requesterFamilyId() == resource.data.familyId
        );

      allow create: if isRequester(uid)
        && request.resource.data.uid == uid;

      allow update: if (
          isRequester(uid)
          && (
            selfProfileOnlyUpdate()
            || selfJoinOrCreateFamilyUpdate(uid)
            || selfLeaveFamilyUpdate()
          )
        )
        || (
          requesterDocExists()
          && resource.data.familyId != null
          && isOwnerOf(resource.data.familyId)
          && request.resource.data.uid == resource.data.uid
          && request.resource.data.email == resource.data.email
          && request.resource.data.displayName == resource.data.displayName
          && request.resource.data.photoURL == resource.data.photoURL
          && request.resource.data.diff(resource.data).changedKeys().hasOnly(["familyId", "role", "updatedAt"])
          && (
            (request.resource.data.familyId == null && request.resource.data.role == "member")
            || (
              request.resource.data.familyId == resource.data.familyId
              && (request.resource.data.role == "owner" || request.resource.data.role == "member")
            )
          )
        );

      allow delete: if false;
    }

    match /grocery_items/{itemId} {
      allow read: if isFamilyMember(resource.data.get('familyId', null));
      allow create: if isFamilyMember(request.resource.data.get('familyId', null));
      allow update, delete: if isFamilyMember(resource.data.get('familyId', null));
    }

    match /categories/{categoryId} {
      allow read: if isFamilyMember(resource.data.get('familyId', null));
      allow create: if isFamilyMember(request.resource.data.get('familyId', null));
      allow update, delete: if isFamilyMember(resource.data.get('familyId', null));
    }

    match /notifications/{notifId} {
      allow read: if isFamilyMember(resource.data.get('familyId', null));
      allow create: if isFamilyMember(request.resource.data.get('familyId', null));
      allow update, delete: if isFamilyMember(resource.data.get('familyId', null));
    }
  }
}
