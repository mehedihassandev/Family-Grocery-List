rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function userDocPath(uid) {
      return /databases/$(database)/documents/users/$(uid);
    }

    function requesterDocExists() {
      return signedIn() && exists(userDocPath(request.auth.uid));
    }

    function requesterFamilyId() {
      return get(userDocPath(request.auth.uid)).data.get('familyId', null);
    }

    function isRequester(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function isFamilyMember(familyId) {
      return signedIn() && requesterFamilyId() == familyId;
    }

    function isOwnerOf(familyId) {
      return isFamilyMember(familyId)
        && get(/databases/$(database)/documents/families/$(familyId)).data.ownerId == request.auth.uid;
    }

    function isValidRole(role) {
      return role == "owner" || role == "member";
    }

    match /families/{familyId} {
      // Family details are private to members.
      // Invite-code lookup is allowed via constrained list query (limit=1).
      allow get: if isFamilyMember(familyId);
      allow list: if signedIn() && request.query.limit != null && request.query.limit <= 1;

      allow create: if signedIn()
        && request.resource.data.ownerId == request.auth.uid
        && request.resource.data.id == familyId
        && request.resource.data.name is string
        && request.resource.data.name.size() > 0
        && request.resource.data.name.size() <= 40
        && request.resource.data.inviteCode is string
        && request.resource.data.inviteCode.matches('^[A-Z0-9]{6}$');

      allow update: if isOwnerOf(familyId)
        && request.resource.data.id == resource.data.id
        && request.resource.data.ownerId == resource.data.ownerId
        && request.resource.data.inviteCode == resource.data.inviteCode
        && request.resource.data.diff(resource.data).changedKeys().hasOnly(["name", "updatedAt"]);

      allow delete: if isOwnerOf(familyId);
    }

    match /users/{uid} {
      allow read: if isRequester(uid)
        || (
          requesterDocExists()
          && resource.data.familyId != null
          && requesterFamilyId() == resource.data.familyId
        );

      // User can create their own profile doc.
      allow create: if isRequester(uid)
        && request.resource.data.uid == uid;

      // User can update own profile.
      // Family owner can remove/transfer family membership for another member.
      allow update: if (
          isRequester(uid)
          && request.resource.data.uid == resource.data.uid
          && request.resource.data.email == resource.data.email
          && request.resource.data.familyId == resource.data.familyId
          && request.resource.data.role == resource.data.role
          && request.resource.data.diff(resource.data).changedKeys().hasOnly(["displayName", "photoURL", "updatedAt"])
        )
        || (
          requesterDocExists()
          && resource.data.familyId != null
          && isOwnerOf(resource.data.familyId)
          && request.resource.data.uid == resource.data.uid
          && request.resource.data.email == resource.data.email
          && request.resource.data.displayName == resource.data.displayName
          && request.resource.data.photoURL == resource.data.photoURL
          && request.resource.data.diff(resource.data).changedKeys().hasOnly(["familyId", "role", "updatedAt"])
          && (
            // Remove member from family.
            (request.resource.data.familyId == null && request.resource.data.role == "member")
            // Transfer/change role within same family.
            || (
              request.resource.data.familyId == resource.data.familyId
              && isValidRole(request.resource.data.role)
            )
          )
        );

      allow delete: if false;
    }

    match /grocery_items/{itemId} {
      allow read: if isFamilyMember(resource.data.get('familyId', null));
      allow create: if isFamilyMember(request.resource.data.get('familyId', null))
        && request.resource.data.id == itemId
        && request.resource.data.name is string
        && request.resource.data.name.size() > 0
        && request.resource.data.name.size() <= 120
        && request.resource.data.priority in ["Urgent", "Medium", "Low"]
        && request.resource.data.status == "pending"
        && request.resource.data.addedBy.uid == request.auth.uid
        && request.resource.data.get('completedBy', null) == null
        && request.resource.data.get('completedAt', null) == null;

      allow update: if isFamilyMember(resource.data.get('familyId', null))
        && request.resource.data.id == resource.data.id
        && request.resource.data.familyId == resource.data.familyId
        && request.resource.data.addedBy == resource.data.addedBy
        && request.resource.data.diff(resource.data).changedKeys().hasOnly([
          "name",
          "category",
          "priority",
          "quantity",
          "notes",
          "status",
          "completedBy",
          "completedAt",
          "updatedAt"
        ])
        && (
          // Non-status edits
          request.resource.data.status == resource.data.status
          // Pending -> completed
          || (
            resource.data.status == "pending"
            && request.resource.data.status == "completed"
            && request.resource.data.completedBy.uid == request.auth.uid
          )
          // Completed -> pending
          || (
            resource.data.status == "completed"
            && request.resource.data.status == "pending"
            && request.resource.data.get('completedBy', null) == null
            && request.resource.data.get('completedAt', null) == null
          )
        );

      allow delete: if isFamilyMember(resource.data.get('familyId', null));
    }

    match /categories/{categoryId} {
      allow read: if isFamilyMember(resource.data.get('familyId', null));
      allow create: if isFamilyMember(request.resource.data.get('familyId', null))
        && request.resource.data.id == categoryId
        && request.resource.data.name is string
        && request.resource.data.name.size() > 0
        && request.resource.data.name.size() <= 40;
      allow update: if isFamilyMember(resource.data.get('familyId', null))
        && request.resource.data.id == resource.data.id
        && request.resource.data.familyId == resource.data.familyId
        && request.resource.data.diff(resource.data).changedKeys().hasOnly(["name"])
        && request.resource.data.name is string
        && request.resource.data.name.size() > 0
        && request.resource.data.name.size() <= 40;
      allow delete: if isFamilyMember(resource.data.get('familyId', null));
    }

    match /notifications/{notifId} {
      allow read: if isFamilyMember(resource.data.get('familyId', null));
      allow create: if isFamilyMember(request.resource.data.get('familyId', null))
        && request.resource.data.id == notifId
        && request.resource.data.actorId == request.auth.uid
        && request.resource.data.readBy is list
        && request.resource.data.readBy.size() == 0;

      allow update: if isFamilyMember(resource.data.get('familyId', null))
        && request.resource.data.id == resource.data.id
        && request.resource.data.familyId == resource.data.familyId
        && request.resource.data.actorId == resource.data.actorId
        && request.resource.data.actorName == resource.data.actorName
        && request.resource.data.type == resource.data.type
        && request.resource.data.title == resource.data.title
        && request.resource.data.message == resource.data.message
        && request.resource.data.itemId == resource.data.itemId
        && request.resource.data.itemName == resource.data.itemName
        && request.resource.data.createdAt == resource.data.createdAt
        && request.resource.data.diff(resource.data).changedKeys().hasOnly(["readBy"])
        && (
          // No-op allowed
          request.resource.data.readBy == resource.data.readBy
          // Add requester read receipt once
          || (
            !resource.data.readBy.hasAny([request.auth.uid])
            && request.resource.data.readBy.hasAll(resource.data.readBy)
            && request.resource.data.readBy.hasAny([request.auth.uid])
            && request.resource.data.readBy.size() == resource.data.readBy.size() + 1
          )
        );

      allow delete: if false;
    }
  }
}
